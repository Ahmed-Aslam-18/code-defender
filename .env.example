# Copy this file to .env and fill in your values.
# .env is gitignored so your secrets are never committed.

# GitHub App (API as the app bot — required for PR file reads and review comments)
GITHUB_APP_ID=123456
# PEM: inline (real newlines or one line with \n), or path to a .pem file from repo root
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GITHUB_APP_PRIVATE_KEY=./your-app.private-key.pem

GITHUB_WEBHOOK_SECRET=your_github_webhook_secret
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key

# Optional
PORT=3000
